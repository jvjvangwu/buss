# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=3000
HOST=localhost

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://username:password@localhost:5432/forum_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forum_db
DB_USER=forum_user
DB_PASSWORD=forum_password
DB_SSL=false

# ==================== Redis配置 ====================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT配置 ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 密码加密配置 ====================
BCRYPT_ROUNDS=12

# ==================== 邮件配置 ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@forum.com
MAIL_FROM_NAME=论坛系统

# ==================== 应用配置 ====================
APP_NAME=论坛系统
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
API_PREFIX=/api

# ==================== 速率限制配置 ====================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_MAX=10
PASSWORD_RESET_RATE_LIMIT_MAX=3

# ==================== CORS配置 ====================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log

# ==================== 文件上传配置 ====================
MAX_FILE_SIZE=5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif
UPLOAD_DIR=uploads

# ==================== 安全配置 ====================
REQUIRE_EMAIL_VERIFICATION=true
ALLOW_REGISTRATION=true
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME_MINUTES=15

# ==================== 测试配置 ====================
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/forum_test_db